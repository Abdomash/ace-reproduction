# Local Deployment Configuration for Multi-Agent System
# Copy this to .env and adjust as needed

# ============================================
# Agent Ports (A2A Protocol)
# ============================================
PLANNER_HOST=127.0.0.1
PLANNER_PORT=10001

WRITER_HOST=127.0.0.1
WRITER_PORT=10002

EDITOR_HOST=127.0.0.1
EDITOR_PORT=10003

# ============================================
# Coordinator (API mode for local deployment)
# ============================================
COORDINATOR_HOST=0.0.0.0
COORDINATOR_PORT=8093

# Coordinator needs to know where the other agents are
CONTENT_PLANNER_AGENT_URL=http://127.0.0.1:10001
CONTENT_WRITER_AGENT_URL=http://127.0.0.1:10002
CONTENT_EDITOR_AGENT_URL=http://127.0.0.1:10003

# ============================================
# LLM Provider Configuration (Real LLM)
# ============================================
# Set PROVIDER to google, aliyun, or ollama and fill in the fields below.
PROVIDER=ollama
# Set MODEL to a model available in your provider (for Ollama, use a local model name).
MODEL=gpt-3.5-turbo
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_API_KEY=dummy

# ============================================
# Optional: Provider keys
# ============================================
# GOOGLE_API_KEY=your_key_here
# ALIYUN_API_KEY=your_key_here

# ============================================
# Google LLM (example switch)
# ============================================
# Example (uncomment and fill in):
# PROVIDER=google
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=your-gcp-region
# GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name
